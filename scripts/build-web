#!/bin/zsh
set -euo pipefail

REPO_DIR=$(cd "$(dirname "$0")/.." && pwd)
RESOURCES_DIR="$REPO_DIR/FreeLook/QuickLookExtension/Resources"

cd "$REPO_DIR/WebRenderer"
bun run build

cp dist/bundle.js "$RESOURCES_DIR/bundle.js"
cp node_modules/github-markdown-css/github-markdown.css "$RESOURCES_DIR/github-markdown.css"
